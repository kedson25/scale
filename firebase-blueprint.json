{
  "entities": {
    "Posto": {
      "title": "Posto",
      "description": "Uma vaga de trabalho",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "numero": { "type": "number", "description": "Número do posto (1-20)" },
        "turno1UserId": { "type": "string", "description": "User ID para o primeiro turno" },
        "turno2UserId": { "type": "string", "description": "User ID para o segundo turno" },
        "instrucaoTurno1": { "type": "string", "description": "Instrução para a troca" },
        "instrucaoTurno2": { "type": "string", "description": "Instrução para a troca" }
      },
      "required": ["id", "numero"]
    }
  },
  "firestore": {
    "/postos/{postoId}": {
      "schema": "Posto",
      "description": "Collection de postos de trabalho"
    }
  }
}
